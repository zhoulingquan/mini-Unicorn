        "args": ["-y", "@modelcontextprotocol/server-brave-search"]
      },
      "fields": [
        {
          "name": "api_key",
          "label": "Brave Search API Key",
          "target": ["env", "BRAVE_API_KEY"],
          "secret": true,
          "required": true,
          "env_var": "BRAVE_API_KEY",
          "placeholder": "BSAxxxxxxxxxxxx"
        }
      ],
      "requires": "Node.js + Brave API Key",
      "note": "在 https://brave.com/search/api/ 免费申请 API Key。"
    },
